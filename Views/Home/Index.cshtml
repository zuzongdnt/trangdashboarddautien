@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Trang chủ";
    var role = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
}

@section Styles {
<style>
    .hero-title {
        letter-spacing: -0.04em;
        line-height: 0.95;
        text-transform: lowercase;
    }

    /* ── HERO SECTION ── */
    .hero {
        position: relative;
        height: 100vh;
        width: 100%;
        overflow: hidden;
        background: #000;
    }

    .hero-video {
        position: absolute;
        inset: 0;
        width: 100%; height: 100%;
        object-fit: cover;
        opacity: 0.65;
    }

    /* Gradient overlay */
    .hero-gradient {
        pointer-events: none;
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 12rem;
        background: linear-gradient(to bottom, transparent, #000);
        z-index: 2;
    }

    /* ── FOREGROUND ── */
    .hero-fg {
        position: relative;
        height: 100%;
        width: 100%;
        z-index: 3;
    }

    /* ── STAGGERED WORDS ── */
    .word-protect {
        position: absolute;
        left: 2.5rem;
        top: 18%;
        font-size: 13vw;
        font-weight: 500;
        color: #fff;
        opacity: 0;
        transform: translateY(40px);
        animation: fadeUp 0.9s cubic-bezier(.22,1,.36,1) 0.15s forwards;
    }

    .word-your {
        position: absolute;
        right: 2.5rem;
        top: 38%;
        font-size: 13vw;
        font-weight: 500;
        color: #fff;
        opacity: 0;
        transform: translateY(40px);
        animation: fadeUp 0.9s cubic-bezier(.22,1,.36,1) 0.35s forwards;
    }

    .word-data {
        position: absolute;
        left: 28%;
        top: 58%;
        font-size: 13vw;
        font-weight: 500;
        color: #fff;
        opacity: 0;
        transform: translateY(40px);
        animation: fadeUp 0.9s cubic-bezier(.22,1,.36,1) 0.55s forwards;
    }

    @@keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }

    /* ── DESCRIPTION ── */
    .hero-desc {
        position: absolute;
        left: 2.5rem;
        top: 46%;
        max-width: 220px;
        font-size: 14px;
        line-height: 1.45;
        color: rgba(255,255,255,0.85);
        opacity: 0;
        animation: fadeUp 0.9s cubic-bezier(.22,1,.36,1) 0.7s forwards;
    }

    /* ── STAT BLOCKS ── */
    .stat-block {
        position: absolute;
        opacity: 0;
        animation: fadeUp 0.9s cubic-bezier(.22,1,.36,1) 0.9s forwards;
    }

    .stat-top-right {
        top: 14%;
        right: 6rem;
        text-align: right;
    }

    .stat-bottom-left {
        left: 5rem;
        bottom: 6rem;
        text-align: left;
    }

    .stat-bottom-right {
        right: 5rem;
        bottom: 5rem;
        text-align: right;
    }

    .stat-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .stat-row.right { justify-content: flex-end; }

    .stat-number {
        font-size: clamp(2rem, 4vw, 3.5rem);
        font-weight: 500;
        letter-spacing: -0.03em;
        color: #fff;
        line-height: 1;
    }

    .stat-divider {
        height: 1px;
        width: 5rem;
        background: rgba(255,255,255,0.35);
    }

    .stat-divider.up   { transform: rotate(20deg); }
    .stat-divider.down { transform: rotate(-20deg); }

    .stat-label {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.6);
        margin-top: 0.25rem;
    }

    /* ── ROLE BADGE ── */
    .role-badge {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        background: rgba(23,23,23,0.9);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 9999px;
        padding: 0.75rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        opacity: 0;
        animation: fadeUp 0.9s cubic-bezier(.22,1,.36,1) 1.1s forwards;
    }

    .role-badge-text {
        font-size: 0.875rem;
        color: rgba(255,255,255,0.8);
    }

    .role-badge-cta {
        background: #fff;
        color: #000;
        font-family: inherit;
        font-size: 0.8rem;
        font-weight: 500;
        border: none;
        border-radius: 9999px;
        padding: 0.45rem 1.1rem;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.2s;
        white-space: nowrap;
    }

    .role-badge-cta:hover { background: #e5e5e5; color: #000; }

    /* Mobile */
    @@media (max-width: 768px) {
        .word-protect, .word-your, .word-data { font-size: 18vw; }
        .word-protect { left: 1rem; }
        .word-your { right: 1rem; }
        .word-data { left: 10%; }
        .hero-desc { left: 1rem; max-width: 180px; font-size: 13px; }
        .stat-divider { display: none; }
        .stat-top-right { right: 1.5rem; }
        .stat-bottom-left { left: 1.5rem; bottom: 8rem; }
        .stat-bottom-right { right: 1.5rem; bottom: 7rem; }
    }
</style>
}

<section class="hero">

    <!-- Background video -->
    <video class="hero-video" autoplay loop muted playsinline
           src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260418_063509_7d167302-4fd4-480b-8260-18ab572333d4.mp4">
    </video>

    <!-- Bottom gradient -->
    <div class="hero-gradient"></div>

    <!-- Foreground -->
    <div class="hero-fg">

        <!-- Staggered headline -->
        <h1 class="hero-title word-protect">quản lý</h1>
        <h1 class="hero-title word-your">tài</h1>
        <h1 class="hero-title word-data">khoản</h1>

        <!-- Description -->
        <p class="hero-desc">
            hệ thống quản lý tài khoản bảo mật, tiện lợi và hiện đại dành cho doanh nghiệp của bạn
        </p>

        <!-- Stat — top right -->
        <div class="stat-block stat-top-right">
            <div class="stat-row right">
                <div class="stat-divider up"></div>
                <span class="stat-number">+10k</span>
            </div>
            <div class="stat-label">tài khoản đang hoạt động</div>
        </div>

        <!-- Stat — bottom left -->
        <div class="stat-block stat-bottom-left">
            <div class="stat-row">
                <span class="stat-number">99.9%</span>
                <div class="stat-divider down"></div>
            </div>
            <div class="stat-label">uptime hệ thống</div>
        </div>

        <!-- Stat — bottom right -->
        <div class="stat-block stat-bottom-right">
            <div class="stat-row right">
                <div class="stat-divider down"></div>
                <span class="stat-number">+300</span>
            </div>
            <div class="stat-label" style="text-align:right">doanh nghiệp tin dùng</div>
        </div>

        <!-- Role-aware action badge -->
        @if (role == "Admin")
        {
            <div class="role-badge">
                <span class="role-badge-text">xin chào, <strong>ông chủ</strong> 👋</span>
                <a asp-controller="TaiKhoan" asp-action="Dashboard" class="role-badge-cta">vào quản trị</a>
            </div>
        }
        else if (role == "Customer")
        {
            <div class="role-badge">
                <span class="role-badge-text">chào mừng bạn quay trở lại 🛍</span>
                <a asp-controller="Home" asp-action="Index" class="role-badge-cta">xem đơn hàng</a>
            </div>
        }
        else
        {
            <div class="role-badge">
                <span class="role-badge-text">chưa đăng nhập</span>
                <a asp-controller="TaiKhoan" asp-action="Login" class="role-badge-cta">đăng nhập ngay</a>
            </div>
        }

    </div>
</section>
